---
const { title, description, cover } = Astro.props
const defaultCover = '/../img/cover.webp'
const imageUrl = new URL(cover ?? defaultCover, Astro.site ?? Astro.url).href
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Meta -->
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mateus Villain" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mateusvillain.com/blog" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${imageUrl}`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://mateusvillain.com/blog" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${imageUrl}`} />

    <!-- Google Tag Manager -->
    <script is:inline>
      ;(function (w, d, l, i) {
        w[l] = w[l] || []
        w[l].push({
          'gtm.start': Date.now(),
          event: 'gtm.js',
        })

        const f = d.getElementsByTagName('script')[0]
        const j = d.createElement('script')
        const dl = l !== 'dataLayer' ? '&l=' + l : ''

        j.async = true
        j.src = `https://www.googletagmanager.com/gtm.js?id=${i}${dl}`

        f.parentNode && f.parentNode.insertBefore(j, f)
      })(window, document, 'dataLayer', 'GTM-NTD9ZL6W')
    </script>

    <link rel="canonical" href={Astro.url.href} />
    <link rel="stylesheet" href="../blog.css" />
    <link rel="stylesheet" href="../style.css" />
    <link rel="icon" type="image/x-icon" href="img/favicon.png" />
  </head>

  <body data-theme="light">
    <div class="container">
      <section class="post-list">
        <slot />
      </section>
      <div class="card card__border p--fixed-24" id="newsletter-card">
        <div class="newsletter-head">
          <h2 class="block-title">Assine a newsletter</h2>
          <p class="body--lg">
            Receba os melhores conteúdos direto no seu e-mail
          </p>
        </div>

        <form class="newsletter-form" id="newsletter-form">
          <div class="form__group form__lg">
            <label for="email">E-mail</label>
            <input
              type="email"
              name="email"
              id="email"
              placeholder="seu@email.com"
              class="form__lg"
              required
            />
          </div>

          <input type="hidden" name="embed" value="1" />

          <button type="submit" class="btn btn--primary btn--lg">
            Assinar
          </button>
        </form>

        <div id="newsletter-error" hidden aria-live="polite">
          <div class="alert alert--danger">
            <div class="alert__content">
              <div class="alert__text">
                <p class="body--lg" id="newsletter-error-message">Não foi possível enviar sua inscrição. Tente novamente.</p>
              </div>
            </div>
          </div>
        </div>

        <div id="newsletter-success" hidden>
          <div class="alert alert--success">
            <div class="alert__content">
              <div class="alert__text">
                <p class="body--lg">Quase lá. Enviamos um e-mail para confirmar sua inscrição.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="/blog/js/form.js" defer></script>
  </body>
</html>
