{
  "name": "personal-site",
  "version": "2.14.1",
  "description": "",
  "main": "dist/index.html",
  "scripts": {
    "dev": "npm run build:assets && astro dev",
    "build": "npm run build:assets && astro build && npm run build:img && npm run build:sitemap && npm run build:robots",
    "preview": "astro preview",
    "build:assets": "npm run build:css:general && npm run build:css:blog && npm run copy:lets-ui",
    "build:css:general": "sass src/sass/general.scss public/style.css --style=compressed --no-source-map",
    "build:css:blog": "sass src/sass/blog.scss public/blog.css --style=compressed --no-source-map",
    "copy:lets-ui": "cp node_modules/@lets-ui/styles/dist/letsui.min.css public/letsui.min.css",
    "build:sitemap": "node sitemap.js",
    "build:robots": "node robots.js",
    "build:img": "node scripts/images.js",
    "release:major": "npm version major && git push origin main --tags",
    "release:minor": "npm version minor && git push origin main --tags",
    "release:patch": "npm version patch && git push origin main --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateusvillain/personal-site.git"
  },
  "keywords": [
    "personal",
    "site",
    "portfolio",
    "design system"
  ],
  "author": "Mateus Villain",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/mateusvillain/personal-site/issues"
  },
  "homepage": "https://github.com/mateusvillain/personal-site#readme",
  "devDependencies": {
    "prettier": "^3.8.1",
    "sass": "^1.94.2",
    "vercel": "^50.8.1"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@lets-ui/components": "^1.1.1",
    "@lets-ui/css": "^0.17.1",
    "@lets-ui/styles": "^1.1.1",
    "@notionhq/client": "^5.6.0",
    "astro": "^5.18.1",
    "dotenv": "^17.2.3",
    "glob": "^13.0.3",
    "sharp": "^0.34.5"
  }
}
