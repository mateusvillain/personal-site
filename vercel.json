{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/lang/(.*)\\.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/dist/(.*)\\.(css|js|png|jpg|jpeg|webp|svg|gif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/locaweb-design-system",
      "destination": "/portfolio/locaweb-design-system",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/portfolio/locaweb-design-system",
      "destination": "/locaweb-design-system"
    }
  ]
}
